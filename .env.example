# =============================================================================
# 建設工事 新規入場管理システム - 環境変数設定
# このファイルを .env にコピーして値を設定してください
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
DB_PASSWORD=changeme_dev_password

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=changeme_dev_password

# -----------------------------------------------------------------------------
# MinIO (ファイルストレージ)
# -----------------------------------------------------------------------------
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme_dev_password
MINIO_BUCKET=entry-documents

# -----------------------------------------------------------------------------
# アプリケーション
# -----------------------------------------------------------------------------
# CORS 許可オリジン（カンマ区切り）
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:80

# ログレベル: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=DEBUG

# -----------------------------------------------------------------------------
# 管理画面 IP 制限（本番環境で設定）
# カンマ区切りの CIDR 形式で社内 IP を指定
# TODO: 本番デプロイ時に設定すること
# ALLOWED_ADMIN_CIDRS=192.168.0.0/16,10.0.0.0/8
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# JWT 署名鍵
# 本番環境では必ず長いランダム文字列に変更すること！
# 生成コマンド: python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_use_python_secrets_token_hex_32

# アクセストークン有効期限（分）
ACCESS_TOKEN_EXPIRE_MINUTES=30

# リフレッシュトークン有効期限（日）
REFRESH_TOKEN_EXPIRE_DAYS=7

# ログイン失敗ロック設定
MAX_LOGIN_FAILURES=5
ACCOUNT_LOCK_MINUTES=30

# -----------------------------------------------------------------------------
# フロントエンド URL（QR コードに埋め込む URL）
# TODO: 本番デプロイ時に実際のドメインを設定すること
# PUBLIC_ENTRY_BASE_URL=https://entry.example.com
# ADMIN_BASE_URL=https://admin.example.com
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# 初期管理者アカウント（初回起動時のみ使用）
# TODO: Day3 の認証実装時に設定すること
# INITIAL_ADMIN_EMAIL=admin@example.com
# INITIAL_ADMIN_PASSWORD=changeme_in_production
# -----------------------------------------------------------------------------
