# =============================================================================
# 本番環境設定テンプレート
# このファイルをコピーして実際の値を設定してください:
#   cp .env.production .env
# .env は .gitignore に追加済みで、Git にコミットされません。
# =============================================================================

# -----------------------------------------------------------------------------
# ドメイン (必須)
# Nginx の server_name と TLS 証明書に使用する
# -----------------------------------------------------------------------------
DOMAIN=entry.example.com

# -----------------------------------------------------------------------------
# PostgreSQL
# 12 文字以上のランダムパスワードを設定すること
# 生成例: openssl rand -base64 18 | tr -dc 'a-zA-Z0-9' | head -c 24
# -----------------------------------------------------------------------------
DB_PASSWORD=CHANGE_THIS_STRONG_DB_PASSWORD

# -----------------------------------------------------------------------------
# Redis
# 12 文字以上のランダムパスワードを設定すること
# -----------------------------------------------------------------------------
REDIS_PASSWORD=CHANGE_THIS_STRONG_REDIS_PASSWORD

# -----------------------------------------------------------------------------
# MinIO (ファイルストレージ)
# MinIO のアクセスキー / シークレットキーは 20 文字以上推奨
# -----------------------------------------------------------------------------
MINIO_ACCESS_KEY=CHANGE_THIS_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_THIS_STRONG_MINIO_SECRET_KEY
MINIO_BUCKET=entry-documents

# -----------------------------------------------------------------------------
# JWT 署名鍵 (必須 — 最重要)
# 32 バイト以上のランダム文字列を設定すること
# 生成コマンド:
#   python -c "import secrets; print(secrets.token_hex(32))"
#   または: openssl rand -hex 32
# この値が漏洩するとすべての JWT トークンが偽造可能になる！
# -----------------------------------------------------------------------------
SECRET_KEY=CHANGE_THIS_WITH_64_HEX_CHARS_MINIMUM_USE_python_secrets_token_hex_32

# -----------------------------------------------------------------------------
# トークン有効期限
# -----------------------------------------------------------------------------
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# ログイン失敗ロック
# -----------------------------------------------------------------------------
MAX_LOGIN_FAILURES=5
ACCOUNT_LOCK_MINUTES=30

# -----------------------------------------------------------------------------
# ログレベル
# 本番では INFO を推奨 (DEBUG は詳細すぎてディスクを圧迫する場合あり)
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# バックアップ保持期間 (日数)
# backup コンテナが古いバックアップを自動削除するまでの日数
# -----------------------------------------------------------------------------
BACKUP_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# Let's Encrypt (certbot 用)
# 証明書取得コマンドで使用: --email ${CERTBOT_EMAIL}
# -----------------------------------------------------------------------------
CERTBOT_EMAIL=your-email@example.com
